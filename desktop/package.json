{
  "name": "proq-desktop",
  "version": "0.1.0",
  "description": "Desktop shell for proq — AI coding task board",
  "main": "dist-main/index.js",
  "author": "proq",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -n main,renderer \"tsc -w -p tsconfig.json\" \"vite build --watch -c vite.config.ts\" & sleep 2 && electron .",
    "dev:main": "tsc -w -p tsconfig.json",
    "dev:renderer": "vite dev -c vite.config.ts",
    "dev:electron": "electron .",
    "build:main": "tsc -p tsconfig.json",
    "build:renderer": "vite build -c vite.config.ts",
    "build": "npm run build:main && npm run build:renderer",
    "package": "npm run build && electron-builder --mac",
    "package:linux": "npm run build && electron-builder --linux",
    "package:all": "npm run build && electron-builder -ml"
  },
  "dependencies": {
    "fix-path": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.1.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
